// This is your Prisma schema file
// GymApp — Multi-tenant Gym Management Platform
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ROOT
  ACADEMIA
  PROFESSOR
  ALUNO
}

enum AcademiaStatus {
  PENDENTE
  ATIVO
  REJEITADO
}

enum Sexo {
  MASCULINO
  FEMININO
}

/// Aprovação em duas camadas: Academia → Root
enum VinculoStatus {
  PENDENTE_ACADEMIA // aguarda academia aprovar
  PENDENTE_ROOT     // academia aprovou, aguarda Root
  ATIVO
  REJEITADO
  REMOVIDO
}

enum TreinoStatus {
  CADASTRADO   // professor cadastrou, não enviado
  ENVIADO      // notificação disparada para aluno
  ACEITO       // aluno aceitou
  RECUSADO     // aluno recusou
  EM_ABERTO    // aceito mas não iniciado no dia
  EM_EXECUCAO  // aluno iniciou
  CONCLUIDO    // aluno finalizou
}

enum TreinoAtor {
  ALUNO
  PROFESSOR
  ACADEMIA
  SISTEMA
}

// ─── Usuário base ─────────────────────────────────────────────────────────────

model Usuario {
  id           String   @id @default(cuid())
  email        String   @unique
  senha_hash   String
  nome         String
  role         Role
  telefone     String?
  foto_url     String?
  ativo        Boolean  @default(true)
  expo_push_token       String?  // token Expo para push notifications
  web_push_subscription  Json?    // PushSubscription JSON (Web Push API)
  criado_em    DateTime @default(now())
  atualizado_em DateTime @updatedAt

  academia   Academia?  // se role = ACADEMIA
  professor  Professor? // se role = PROFESSOR
  aluno      Aluno?     // se role = ALUNO

  refreshTokens RefreshToken[]

  @@map("usuarios")
}

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  usuario_id String
  expira_em  DateTime
  criado_em  DateTime @default(now())

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Academia (tenant) ────────────────────────────────────────────────────────

model Academia {
  id              String         @id @default(cuid())
  usuario_id      String         @unique
  nome            String
  cnpj            String         @unique
  status          AcademiaStatus @default(PENDENTE)
  max_professores Int            @default(20)
  rejeitado_motivo String?
  criado_em       DateTime       @default(now())
  atualizado_em   DateTime       @updatedAt

  usuario    Usuario              @relation(fields: [usuario_id], references: [id])
  professores ProfessorAcademia[]
  alunos     Aluno[]

  @@map("academias")
}

// ─── Professor ────────────────────────────────────────────────────────────────

model Professor {
  id            String   @id @default(cuid())
  usuario_id    String   @unique
  cref          String?
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  usuario    Usuario              @relation(fields: [usuario_id], references: [id])
  academias  ProfessorAcademia[]
  alunos     Aluno[]

  @@map("professores")
}

/// Vínculo M:N com aprovação em duas camadas
model ProfessorAcademia {
  id             String       @id @default(cuid())
  professor_id   String
  academia_id    String
  status         VinculoStatus @default(PENDENTE_ACADEMIA)
  criado_em      DateTime     @default(now())
  atualizado_em  DateTime     @updatedAt

  professor Professor @relation(fields: [professor_id], references: [id])
  academia  Academia  @relation(fields: [academia_id], references: [id])

  @@unique([professor_id, academia_id])
  @@map("professor_academia")
}

// ─── Aluno ────────────────────────────────────────────────────────────────────

model Aluno {
  id              String    @id @default(cuid())
  usuario_id      String    @unique
  professor_id    String?   // null = modo autogestão
  academia_id     String?
  data_nascimento DateTime?
  peso_kg         Float?
  altura_cm       Float?
  sexo            Sexo?
  objetivo_treino String?
  nivel_treino    String?
  restricoes      String[]  @default([])
  visibilidade_padrao       Visibilidade @default(AMIGOS)
  permite_busca_email       Boolean      @default(true)
  consentiu_feed_social_em  DateTime?
  criado_em       DateTime  @default(now())
  atualizado_em   DateTime  @updatedAt

  usuario    Usuario          @relation(fields: [usuario_id], references: [id])
  professor  Professor?       @relation(fields: [professor_id], references: [id])
  academia   Academia?        @relation(fields: [academia_id], references: [id])
  treinos    Treino[]
  medidas    MedidaCorporal[]
  notificacoes Notificacao[]
  mensagensEnviadas MensagemMotivacionalEnviada[]
  correlacao  CorrelacaoDesempenho?

  @@map("alunos")
}

// ─── Treino ───────────────────────────────────────────────────────────────────

model Treino {
  id                     String       @id @default(cuid())
  aluno_id               String
  nome                   String       // ex.: "Treino A — Peito e Tríceps"
  dias_semana            Int[]        // 0=Dom, 1=Seg, ..., 6=Sáb
  status                 TreinoStatus @default(CADASTRADO)
  avaliacao_dificuldade  String?      // FACIL, MODERADO, INTENSO, MUITO_INTENSO
  is_template            Boolean      @default(false)
  iniciado_em            DateTime?
  finalizado_em          DateTime?
  criado_em              DateTime     @default(now())
  atualizado_em          DateTime     @updatedAt

  aluno      Aluno               @relation(fields: [aluno_id], references: [id])
  exercicios TreinoExercicio[]
  historico  TreinoHistorico[]
  execucoes  ExecucaoExercicio[]

  @@map("treinos")
}

/// Log imutável de transições de estado — append-only
model TreinoHistorico {
  id              String       @id @default(cuid())
  treino_id       String
  status_anterior TreinoStatus
  status_novo     TreinoStatus
  ator_id         String       // usuario_id de quem acionou (ou "SISTEMA")
  ator_tipo       TreinoAtor
  timestamp       DateTime     @default(now())

  treino Treino @relation(fields: [treino_id], references: [id])

  @@map("treino_historico")
}

// ─── Exercício ────────────────────────────────────────────────────────────────

model Exercicio {
  id                   String   @id @default(cuid())
  nome                 String
  maquina              String?
  dica                 String?  @db.Text
  imagem_url           String?
  gif_url              String?           // URL do GIF animado
  descricao_pt         String?  @db.Text // descrição completa em português
  passos_pt            String[]           // passos de execução em português
  musculo_alvo         String?            // músculo alvo principal
  musculos_secundarios String[]           // músculos secundários
  nivel                String?
  grupo_muscular       String?
  equipamento          String?
  criado_em            DateTime @default(now())
  atualizado_em        DateTime @updatedAt

  treinos                 TreinoExercicio[]
  execucoes               ExecucaoExercicio[]
  planoSessaoExercicios   PlanoSessaoExercicio[] @relation("ExercicioBase")
  planoSessaoAlternativos PlanoSessaoExercicio[] @relation("ExercicioAlternativo")

  @@map("exercicios")
}

/// Associação Treino ↔ Exercício com ordem, séries e reps prescritas
model TreinoExercicio {
  id            String @id @default(cuid())
  treino_id     String
  exercicio_id  String
  ordem         Int
  tipo          String @default("PRINCIPAL") // AQUECIMENTO | PRINCIPAL | ALONGAMENTO
  series        Int    @default(3)
  repeticoes    Int    @default(12)
  carga_sugerida_kg Float?

  treino    Treino    @relation(fields: [treino_id], references: [id])
  exercicio Exercicio @relation(fields: [exercicio_id], references: [id])

  @@unique([treino_id, ordem])
  @@map("treino_exercicios")
}

// ─── Biblioteca de Planos de Treino ──────────────────────────────────────────

model PlanoBiblioteca {
  id              String   @id @default(cuid())
  codigo          String   @unique
  nome            String
  descricao       String?  @db.Text
  objetivo        String   // HIPERTROFIA | FORCA | EMAGRECIMENTO | SAUDE
  nivel           String   // INICIANTE | INTERMEDIARIO | AVANCADO
  sexo_alvo       String   @default("AMBOS") // MASCULINO | FEMININO | AMBOS
  dias_por_semana Int
  split_tipo      String   // ABC | ABCD | FULL_BODY | UPPER_LOWER etc.
  ativo           Boolean  @default(true)
  criado_em       DateTime @default(now())

  sessoes PlanoSessao[]

  @@map("planos_biblioteca")
}

model PlanoSessao {
  id        String @id @default(cuid())
  plano_id  String
  nome      String // "Treino A — Peito, Tríceps e Ombro"
  dia_label String // "A" | "B" | "C"
  ordem     Int

  plano      PlanoBiblioteca        @relation(fields: [plano_id], references: [id], onDelete: Cascade)
  exercicios PlanoSessaoExercicio[]

  @@map("plano_sessoes")
}

model PlanoSessaoExercicio {
  id                      String   @id @default(cuid())
  sessao_id               String
  exercicio_id            String
  ordem                   Int
  tipo                    String   @default("PRINCIPAL")
  series                  Int      @default(3)
  repeticoes_min          Int      @default(8)
  repeticoes_max          Int      @default(12)
  carga_sugerida_kg       Float?
  restricoes_incompativeis String[] @default([])
  alternativo_id          String?

  sessao      PlanoSessao @relation(fields: [sessao_id], references: [id], onDelete: Cascade)
  exercicio   Exercicio   @relation("ExercicioBase", fields: [exercicio_id], references: [id])
  alternativo Exercicio?  @relation("ExercicioAlternativo", fields: [alternativo_id], references: [id])

  @@unique([sessao_id, ordem])
  @@map("plano_sessao_exercicios")
}

/// Registro de execução real pelo aluno (carga e reps realizadas)
model ExecucaoExercicio {
  id            String   @id @default(cuid())
  treino_id     String
  exercicio_id  String
  serie_numero  Int
  repeticoes    Int
  carga_kg      Float
  registrado_em DateTime @default(now())

  treino    Treino    @relation(fields: [treino_id], references: [id])
  exercicio Exercicio @relation(fields: [exercicio_id], references: [id])

  @@map("execucao_exercicios")
}

// ─── Medidas Corporais ────────────────────────────────────────────────────────

model MedidaCorporal {
  id              String   @id @default(cuid())
  aluno_id        String
  peso_kg         Float?
  altura_cm       Float?
  percentual_bf   Float?
  massa_magra_kg  Float?
  imc             Float?
  data            DateTime @default(now())
  observacao      String?

  aluno Aluno @relation(fields: [aluno_id], references: [id])

  @@map("medidas_corporais")
}

// ─── Notificações ─────────────────────────────────────────────────────────────

model Notificacao {
  id        String           @id @default(cuid())
  aluno_id  String
  tipo      NotificacaoTipo
  mensagem  String
  dados     Json?
  lida      Boolean          @default(false)
  criado_em DateTime         @default(now())

  aluno Aluno @relation(fields: [aluno_id], references: [id])

  @@map("notificacoes")
}

enum NotificacaoTipo {
  PROFESSOR_ATRIBUIDO
  NOVO_TREINO
}

// ─── Módulo Social ──────────────────────────────────────────────────────────

enum FriendshipStatus {
  PENDENTE
  ACEITO
  BLOQUEADO
}

enum PostTipo {
  TREINO_INICIADO
  TREINO_CONCLUIDO
  RECORDE_PESSOAL
  BADGE_CONQUISTADO
  DESAFIO_COMPLETO
}

enum Visibilidade {
  AMIGOS
  PUBLICO
  PRIVADO
}

enum ClubTipo {
  ACADEMIA
  TEMATICO
}

// ─── Mensagens Motivacionais ──────────────────────────────────────────────────

model MensagemMotivacional {
  id         String   @id @default(cuid())
  titulo     String
  resumo     String   @db.Text
  url_estudo String
  criado_em  DateTime @default(now())

  enviadas MensagemMotivacionalEnviada[]

  @@map("mensagens_motivacionais")
}

/// Controle de rotação circular por aluno (UC-28 / UC-33)
model MensagemMotivacionalEnviada {
  id            String   @id @default(cuid())
  aluno_id      String
  mensagem_id   String
  enviada_em    DateTime @default(now())

  aluno    Aluno                @relation(fields: [aluno_id], references: [id])
  mensagem MensagemMotivacional @relation(fields: [mensagem_id], references: [id])

  @@map("mensagens_motivacionais_enviadas")
}

// ─── Correlações de Desempenho ──────────────────────────────────────────────

/// Cache de correlações (UC-32) — worker recalcula, endpoint lê
/// Sugere atualização quando calculado_em > 30 dias
model CorrelacaoDesempenho {
  id                     String   @id @default(cuid())
  aluno_id               String   @unique
  peso_volume_r          Float?   // Pearson r: variação de peso vs volume de carga
  bf_volume_r            Float?   // Pearson r: variação de %BF vs volume de carga
  massa_magra_volume_r   Float?   // Pearson r: variação de massa magra vs volume
  volume_semanal         Json     // [{ semana, volumeTotalKg, treinos }]
  pontos                 Json     // [{ data, deltaPesoKg, deltaBf, deltaMassaMagraKg, volumeAcumuladoKg }]
  calculado_em           DateTime @default(now())

  aluno Aluno @relation(fields: [aluno_id], references: [id], onDelete: Cascade)

  @@map("correlacoes_desempenho")
}

// ─── Módulo Social ───────────────────────────────────────────────────────────

model SocialFriendship {
  id        String           @id @default(cuid())
  aluno_id  String
  amigo_id  String
  status    FriendshipStatus @default(PENDENTE)
  criado_em DateTime         @default(now())

  @@unique([aluno_id, amigo_id])
  @@index([amigo_id, status])
  @@map("social_friendships")
}

model SocialPost {
  id                    String       @id @default(cuid())
  aluno_id              String
  treino_id             String?      // referência lógica, sem FK formal
  clube_id              String?
  autor_nome            String
  autor_foto_url        String?
  grupo_muscular_resumo String?
  academia_nome         String?   // desnormalizado para evitar JOIN no feed
  tipo                  PostTipo
  visibilidade          Visibilidade
  midia_url             String?
  curtidas_count        Int          @default(0)
  comentarios_count     Int          @default(0)
  criado_em             DateTime     @default(now())

  @@index([aluno_id, criado_em])
  @@index([clube_id, criado_em])
  @@index([visibilidade, criado_em])
  @@map("social_posts")
}

model SocialLike {
  id       String @id @default(cuid())
  post_id  String
  aluno_id String

  @@unique([post_id, aluno_id])
  @@index([post_id])
  @@map("social_likes")
}

model SocialComment {
  id         String   @id @default(cuid())
  post_id    String
  aluno_id   String
  autor_nome String
  texto      String   @db.VarChar(280)
  criado_em  DateTime @default(now())

  @@index([post_id, criado_em])
  @@map("social_comments")
}

model SocialClub {
  id           String    @id @default(cuid())
  academia_id  String?   @unique  // 1:1 com academia, null se TEMATICO
  nome         String
  tipo         ClubTipo  @default(ACADEMIA)
  criado_em    DateTime  @default(now())

  @@map("social_clubs")
}

model SocialClubMember {
  id        String   @id @default(cuid())
  clube_id  String
  aluno_id  String
  xp_semana Int      @default(0)
  criado_em DateTime @default(now())

  @@unique([clube_id, aluno_id])
  @@index([clube_id, xp_semana])
  @@map("social_club_members")
}
