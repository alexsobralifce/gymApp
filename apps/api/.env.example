# Variáveis de Ambiente — GymApp API
# Copie este arquivo para .env e preencha os valores

# ─── Aplicação ────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_BASE_URL=http://localhost:3333

# ─── Banco de Dados ───────────────────────────────────
DATABASE_URL="postgresql://gymapp:gymapp@localhost:5432/gymapp_dev?schema=public"

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=troque_por_segredo_forte_em_producao
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_outro_segredo_forte
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (S3 / Cloudflare R2) ─────────────────────
STORAGE_BUCKET=gymapp-dev
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ─── Web Push (VAPID keys) ─────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gymapp.com

# ─── IA / LLM ──────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=

